# ─── GROW Strategy Dashboard — Variables de Entorno ───────────────────────────
# Copia este archivo como .env y rellena tus valores
# En Railway: configura estas variables en Settings > Variables

# ── Telegram ───────────────────────────────────────────────────────────────────
# 1. Habla con @BotFather en Telegram, crea un bot → te dará el TOKEN
# 2. Para obtener tu CHAT_ID: escribe a @userinfobot o envía /start a tu bot
#    y visita: https://api.telegram.org/bot<TU_TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=1234567890:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-1001234567890

# ── Seguridad (opcional) ────────────────────────────────────────────────────────
# Si defines esta clave, el botón "Iniciar Scan" del dashboard
# requerirá el header X-API-Key. Déjalo vacío para acceso libre.
SCAN_API_KEY=

# ── Scan Automático ─────────────────────────────────────────────────────────────
# true  → escanea automáticamente a las 9:35 y 15:55 ET (lun-vie)
# false → solo manual desde el dashboard
AUTO_SCAN=false

# Número de acciones a escanear en auto-scan o por defecto
SCAN_STOCKS=50
